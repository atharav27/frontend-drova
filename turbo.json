{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NEXT_PUBLIC_MARKETPLACE_URL",
    "NEXT_PUBLIC_MARKETPLACE_BASE_URL",
    "NEXT_PUBLIC_AUTH_BASE_URL",
    "NEXT_PUBLIC_API_BASE_URL",
    "NEXT_PUBLIC_DRIVERJOBS_URL",
    "NEXT_PUBLIC_DRIVERJOBS_BASE_URL",
    "API_BASE_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["NEXT_PUBLIC_DRIVERJOBS_BASE_URL", "NEXT_PUBLIC_MARKETPLACE_BASE_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["NEXT_PUBLIC_DRIVERJOBS_BASE_URL", "NEXT_PUBLIC_MARKETPLACE_BASE_URL"]
    }
  }
}
